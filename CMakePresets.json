{
  "version": 8,
  "$schema": "https://cmake.org/cmake/help/latest/_downloads/3e2d73bff478d88a7de0de736ba5e361/schema.json",
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_COLOR_DIAGNOSTICS": "ON",
        "CMAKE_VERBOSE_MAKEFILE": "ON",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF"
      }
    },
    {
      "name": "base-debug",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_INTDIR": "Debug"
      }
    },
    {
      "name": "base-release",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INTDIR": "Release"
      }
    },
    {
      "name": "base-make",
      "hidden": true,
      "inherits": "base",
      "generator": "Unix Makefiles"
    },
    {
      "name": "base-ninja",
      "hidden": true,
      "inherits": "base",
      "generator": "Ninja Multi-Config"
    },
    {
      "name": "base-g++",
      "hidden": true,
      "inherits": "base",
        "cacheVariables": {
          "CMAKE_CXX_COMPILER": "g++"
        }
    },
    {
      "name": "base-clang",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },


    {
      "name": "g++-ninja-debug",
      "hidden": false,
      "inherits": ["base-g++","base-ninja","base-debug"]

    },
    {
      "name": "g++-ninja-release",
      "hidden": false,
      "inherits": ["base-g++","base-ninja","base-release"]

    },
    {
      "name": "clang-ninja-debug",
      "hidden": false,
      "inherits": ["base-clang","base-ninja","base-debug"]

    },
    {
      "name": "clang-ninja-release",
      "hidden": false,
      "inherits": ["base-clang","base-ninja","base-release"]

    },

    {
      "name": "g++-make-debug",
      "hidden": false,
      "inherits": ["base-g++","base-make","base-debug"]

    },
    {
      "name": "g++-make-release",
      "hidden": false,
      "inherits": ["base-g++","base-make","base-release"]

    },
    {
      "name": "clang-make-debug",
      "hidden": false,
      "inherits": ["base-clang","base-make","base-debug"]

    },
    {
      "name": "clang-make-release",
      "hidden": false,
      "inherits": ["base-clang","base-make","base-release"]

    }
  ],
  "buildPresets": [
    {
      "name": "clang-ninja-release",
      "displayName": "clang-ninja-release",
      "configurePreset": "clang-ninja-release"
    },
    {
      "name": "clang-ninja-debug",
      "displayName": "clang-ninja-debug",
      "configurePreset": "clang-ninja-debug"
    },
    {
      "name": "g++-ninja-release",
      "displayName": "g++-ninja-release",
      "configurePreset": "g++-ninja-release"
    },
    {
      "name": "g++-ninja-debug",
      "displayName": "g++-ninja-debug",
      "configurePreset": "g++-ninja-debug"
    },

    {
      "name": "clang-make-release",
      "displayName": "clang-make-release",
      "configurePreset": "clang-make-release"
    },
    {
      "name": "clang-make-debug",
      "displayName": "clang-make-debug",
      "configurePreset": "clang-make-debug"
    },
    {
      "name": "g++-make-release",
      "displayName": "g++-make-release",
      "configurePreset": "g++-make-release"
    },
    {
      "name": "g++-make-debug",
      "displayName": "g++-make-debug",
      "configurePreset": "g++-make-debug"
    }
  ]
}